// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Student {
  id    Int    @id @default(autoincrement())
  name  String
  email String @unique
  grade Int
  gpa   Float
  role  Role   @default(STUDENT)

  @@map("students")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}
